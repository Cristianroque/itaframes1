# Supabase (CMS + login em /login)
# Guia: supabase/SETUP.md — SQL: supabase/migrations/001_cms_schema.sql
#
# Vite expõe variáveis com prefixo VITE_ ou NEXT_PUBLIC_ (ambos funcionam neste projeto).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Alternativa (mesmo significado que em projetos Next.js):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Compat: chave "anon" também aceite como publishable
# VITE_SUPABASE_PUBLISHABLE_KEY=
